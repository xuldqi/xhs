# ============================================
# 后端环境变量配置
# ============================================

# 服务器配置
PORT=3000
NODE_ENV=development

# CORS 配置
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# DeepSeek API 配置
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_API_BASE_URL=https://api.deepseek.com

# Supabase 配置
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# 支付宝配置（官方 SDK）
# 获取方式：
# 1. 登录支付宝开放平台：https://open.alipay.com/
# 2. 创建应用并获取 APPID
# 3. 配置应用公钥，获取支付宝公钥
# 4. 生成应用私钥（使用支付宝密钥生成工具）
ALIPAY_APP_ID=your-app-id-here
# 应用私钥（完整的字符串，包含 -----BEGIN PRIVATE KEY----- 等）
ALIPAY_PRIVATE_KEY=your-private-key-here
# 支付宝公钥（完整的字符串，包含 -----BEGIN PUBLIC KEY----- 等）
ALIPAY_PUBLIC_KEY=your-alipay-public-key-here
# 网关地址：
# 沙箱环境：https://openapi.alipaydev.com/gateway.do
# 生产环境：https://openapi.alipay.com/gateway.do
ALIPAY_GATEWAY=https://openapi.alipaydev.com/gateway.do

# 前端地址（用户支付完成后跳回）
FRONTEND_URL=http://localhost:5173
# 后端公网地址。支付宝异步通知会 POST 到 BACKEND_URL/api/payment/notify，本地开发需用 ngrok 等暴露为 https 后填写
BACKEND_URL=http://localhost:3000

# 请求限制
MAX_REQUEST_SIZE=10mb

# 自动化工作流配置
# 默认兜底 webhook（可不填，建议按工作流分别配置）
N8N_WEBHOOK_URL=
N8N_TREND_SCRAPER_WEBHOOK_URL=
N8N_MULTI_PLATFORM_WEBHOOK_URL=
N8N_AUTO_CONTENT_WEBHOOK_URL=
XIAOHONGSHU_WEBHOOK_URL=
AUTOMATION_PROVIDER_DIRECT_MODE=false

# Provider 适配器配置（可选，开启后支持服务端直连执行）
TWITTER_BEARER_TOKEN=
WEIBO_ACCESS_TOKEN=
UNSPLASH_ACCESS_KEY=

# 回调地址（n8n 执行完成后回写任务状态）
AUTOMATION_CALLBACK_BASE_URL=http://localhost:3000

# Webhook 安全校验（回调签名与来源校验）
AUTOMATION_WEBHOOK_SECRET=replace-with-a-strong-random-secret
AUTOMATION_WEBHOOK_ALLOWED_SOURCES=n8n
AUTOMATION_WEBHOOK_SOURCE=content-factory-backend
AUTOMATION_WEBHOOK_MAX_SKEW_SECONDS=300

# 服务端定时调度器（负责自动派发 scheduled 任务）
AUTOMATION_SCHEDULER_ENABLED=true
AUTOMATION_SCHEDULER_INTERVAL_MS=30000
AUTOMATION_SCHEDULER_BATCH_SIZE=10
